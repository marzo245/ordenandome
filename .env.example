# Neon Postgres (connection string)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# GitHub (Personal Access Token, scope: repo + read:user)
GITHUB_TOKEN=ghp_xxx
GITHUB_USERNAME=marzo245

# Groq (chat rápido: planner, edición simple, resumen)
GROQ_API_KEY=gsk_xxx
# Opcional: segunda key de Groq. Si la primera agota su cuota diaria (429),
# se usa esta antes de caer a Gemini.
GROQ_API_KEY_2=gsk_xxx
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (razonamiento profundo: crear notas con contexto, edición compleja)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Cron: protege /api/summary
CRON_SECRET=pon-un-string-aleatorio-largo

# Auth (NextAuth v5 + Google OAuth)
# Genera AUTH_SECRET con: npx auth secret
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# En prod: NEXTAUTH_URL=https://calendario-inteligente-vr00.onrender.com
NEXTAUTH_URL=http://localhost:3000

# Obsidian vault (repo GitHub con notas markdown)
OBSIDIAN_VAULT_REPO=marzo245/MiMenteObsidian
OBSIDIAN_VAULT_BRANCH=main

# Subida de imágenes (opcional). Si no defines IMGBB_API_KEY, la app usa catbox.moe sin auth.
# Crea tu key gratis en https://api.imgbb.com/
IMGBB_API_KEY=
